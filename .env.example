# ============================================================================
# Antariksha Trek Operations — environment variables (reference)
# Copy the relevant blocks into server/.env and client/.env (both gitignored).
# Never hardcode secrets; never commit real keys.
# ============================================================================

# ---------- Backend (server/.env) ----------
PORT=4000
NODE_ENV=production
CLIENT_ORIGIN=https://your-app.vercel.app

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Supabase (server holds the SERVICE ROLE key — never expose to the browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (OTP + alerts). Leave SMTP_HOST empty in dev to log emails to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Antariksha Ops <no-reply@yourdomain.com>"

# Security tuning
OTP_TTL_SECONDS=300
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# App metadata (optional)
APP_NAME=Antariksha Trek Operations
ADMIN_EMAIL=admin@yourdomain.com

# ---------- Frontend (client/.env) ----------
# The browser only needs the API origin. In local dev this is unset and Vite
# proxies /api -> http://localhost:4000.
VITE_API_URL=https://your-api.up.railway.app

# Provided for reference only — this build talks to Supabase via the Express API,
# not directly from the browser. If you later add direct Supabase client/Storage
# access, set the public (anon) keys here:
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
