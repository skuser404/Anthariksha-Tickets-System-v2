# ---- Server ----
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ---- Auth ----
# Generate strong random values, e.g. `openssl rand -hex 48`
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---- Supabase ----
# Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key (server-only, NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email (OTP + notifications) ----
# Leave SMTP_HOST empty in dev to print emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Antariksha Ops <no-reply@antariksha.local>"

# ---- Security tuning ----
OTP_TTL_SECONDS=300
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
